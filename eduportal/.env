# EduPortal environment template
# Copy this file to .env and fill your local values.

# ── MySQL (primary — takes precedence when MYSQL_HOST is set) ─────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=eduportal_db

# ── PostgreSQL (fallback — used only when MYSQL_HOST is blank) ────────────────
# Option A: full URL
# DATABASE_URL=postgresql://eduportal_app:CHANGE_ME@localhost:5432/eduportal

# Option B: individual variables
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=eduportal_app
POSTGRES_PASSWORD=Shelomoh0126168@2005
POSTGRES_DATABASE=eduportal
POSTGRES_SSLMODE=prefer

# App security
JWT_SECRET_KEY=dev-jwt-secret-change-in-prod

# Optional notification providers
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@eduportal.ss
AT_API_KEY=
AT_SENDER_ID=EduPortal

# ── File storage (S3 / Supabase Storage) ─────────────────────────────────────
# Leave S3_BUCKET blank to use local disk storage (default for development).
#
# AWS S3:
# S3_BUCKET=eduportal-files
# S3_REGION=us-east-1
# S3_ACCESS_KEY=<your-access-key-id>
# S3_SECRET_KEY=<your-secret-access-key>
# S3_ENDPOINT_URL=
# S3_PUBLIC_BASE_URL=
#
# Supabase Storage (S3-compatible):
# S3_BUCKET=eduportal-files
# S3_REGION=us-east-1
# S3_ACCESS_KEY=<supabase-service-role-key>
# S3_SECRET_KEY=<supabase-service-role-key>
# S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
# S3_PUBLIC_BASE_URL=https://<project-ref>.supabase.co/storage/v1/object/public
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=
S3_PUBLIC_BASE_URL=
