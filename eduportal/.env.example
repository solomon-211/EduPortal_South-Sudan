# EduPortal environment template
# Copy this file to .env and fill your local values.

# ── MySQL (primary — takes precedence when MYSQL_HOST is set) ─────────────────
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=eduportal_db

# ── PostgreSQL (fallback — used only when MYSQL_HOST is blank) ────────────────
# Option A: full URL
# DATABASE_URL=postgresql://eduportal_app:CHANGE_ME@localhost:5432/eduportal

# Option B: individual variables
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=eduportal_app
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DATABASE=eduportal
POSTGRES_SSLMODE=prefer

# App security
JWT_SECRET_KEY=dev-jwt-secret-change-in-prod

# Optional notification providers
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@eduportal.ss
AT_API_KEY=
AT_SENDER_ID=EduPortal
