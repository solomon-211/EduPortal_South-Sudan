# EduPortal environment template
# Copy this file to .env and fill in your values.

# Database — MySQL (primary). Leave everything below blank and set
# DATABASE_URL=sqlite:///eduportal.db instead for local development without
# a MySQL server; the app and test suite both run the same way on SQLite.

# Option A: full URL (takes priority when set)
# DATABASE_URL=mysql+pymysql://eduportal_app:CHANGE_ME@localhost:3306/eduportal?charset=utf8mb4

# Option B: individual variables
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=eduportal_app
MYSQL_PASSWORD=CHANGE_ME
MYSQL_DATABASE=eduportal

# App security
JWT_SECRET_KEY=dev-jwt-secret-change-in-prod

# Optional notification providers
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@eduportal.ss
AT_API_KEY=
AT_SENDER_ID=EduPortal

# Web Push (browser notifications) — generate a keypair with:
#   python -c "from py_vapid import Vapid02; v=Vapid02(); v.generate_keys()"
# Leave both blank to disable push; email/SMS/in-app notifications still work.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIMS_SUB=mailto:admin@eduportal.ss

# Google Sign-In — create an OAuth client at https://console.cloud.google.com/apis/credentials
# (Web application type, Authorized JavaScript origin = your site URL)
GOOGLE_CLIENT_ID=

# File storage (S3 / Supabase Storage)
# Leave S3_BUCKET blank to use local disk storage (default for development).
#
# AWS S3:
# S3_BUCKET=eduportal-files
# S3_REGION=us-east-1
# S3_ACCESS_KEY=<your-access-key-id>
# S3_SECRET_KEY=<your-secret-access-key>
# S3_ENDPOINT_URL=
# S3_PUBLIC_BASE_URL=
#
# Supabase Storage (S3-compatible):
# S3_BUCKET=eduportal-files
# S3_REGION=us-east-1
# S3_ACCESS_KEY=<supabase-service-role-key>
# S3_SECRET_KEY=<supabase-service-role-key>
# S3_ENDPOINT_URL=https://<project-ref>.supabase.co/storage/v1/s3
# S3_PUBLIC_BASE_URL=https://<project-ref>.supabase.co/storage/v1/object/public
S3_BUCKET=
S3_REGION=us-east-1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT_URL=
S3_PUBLIC_BASE_URL=
